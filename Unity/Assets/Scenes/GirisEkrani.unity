--- !u!114 &35410578
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 35410576}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Bu sim\xFClasyon, \u201CE\u011Fitim ve Ara\u015Ft\u0131rma Uygulamalar\u0131
    i\xE7in VR Destekli 3B Yaz\u0131c\u0131yla \xDCretilmi\u015F Robotik Cerrahi
    Sisteminin Tasar\u0131m\u0131, Sim\xFClasyonu ve Uygulamas\u0131\u201D adl\u0131
    bitirme projesi kapsam\u0131nda geli\u015Ftirilmi\u015Ftir.\r\n\r\nProjenin amac\u0131,
    cerrahi e\u011Fitim ve ara\u015Ft\u0131rma \xE7al\u0131\u015Fmalar\u0131nda kullan\u0131labilecek
    etkile\u015Fimli bir sanal ger\xE7eklik ortam\u0131 olu\u015Fturmakt\u0131r.
    Kullan\u0131c\u0131, VR ortam\u0131nda cerrahi aletleri alarak do\u011Fru yuvalar\u0131na
    yerle\u015Ftirir ve bu s\xFCre\xE7te ger\xE7ek bir cerrahi \xE7al\u0131\u015Fma
    alan\u0131na benzer bir deneyim ya\u015Far.\r\n\r\nSim\xFClasyon, yaln\u0131zca
    sanal ortamla s\u0131n\u0131rl\u0131 kalmayacak \u015Fekilde tasarlanm\u0131\u015Ft\u0131r.
    Kullan\u0131c\u0131n\u0131n yapt\u0131\u011F\u0131 se\xE7imler ve yerle\u015Ftirme
    i\u015Flemleri, fiziksel bir robotik sistemle ili\u015Fkilendirilebilir. B\xF6ylece
    sanal ortamda yap\u0131lan bir hareketin, ger\xE7ek d\xFCnyadaki robotik sistem
    taraf\u0131ndan takip edilmesi hedeflenmektedir.\r\n\r\nBu sistem; cerrahi aletlerin
    tan\u0131nmas\u0131, do\u011Fru konuma ta\u015F\u0131nmas\u0131 ve robotik sistemlerle
    etkile\u015Fim kurulmas\u0131 gibi konularda e\u011Fitim ve ara\u015Ft\u0131rma
    ama\xE7l\u0131 kullan\u0131labilir. Geli\u015Ftirilmeye a\xE7\u0131k yap\u0131s\u0131
    sayesinde ileride robotik cerrahi e\u011Fitimleri, uzaktan kontrol uygulamalar\u0131
    ve daha geli\u015Fmi\u015F t\u0131bbi sim\xFClasyon sistemleri i\xE7in temel
    olu\u015Fturabilir."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
